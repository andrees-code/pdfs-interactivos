{
  "name": "docflow",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "DocFlow - Plataforma profesional para gestión y edición de PDFs interactivos con IA",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",

# Frontend Environment Variables

# Backend URL - CRÍTICO para Vercel
# En local, usa http://localhost:3000
# En producción Vercel, usa la URL del backend (https://pdfs-bakend.vercel.app)
VITE_BACKEND_URL=https://pdfs-bakend.vercel.app

# Cloudinary (Direct Upload desde navegador)
# Crea un Upload Preset en modo unsigned y pon su nombre aquí
VITE_CLOUDINARY_CLOUD_NAME=demo-cloud-name
VITE_CLOUDINARY_UNSIGNED_PRESET=unsigned_upload_preset

# Conversor PPTX -> PDF (opcional)
# Si no lo usas, deja el valor por defecto del proyecto o comenta esta línea
VITE_GOTENBERG_URL=https://tu-conversor-pptx.ejemplo.com/forms/libreoffice/convert

# Otros servicios (si los usas)
VITE_STRIPE_PUBLIC_KEY=pk_live_xxxxx
VITE_API_TIMEOUT=120000
